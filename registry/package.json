{
  "name": "blockstudio",
  "version": "0.0.1",
  "description": "CLI for adding WordPress blocks from the Blockstudio registry.",
  "license": "MIT",
  "bin": {
    "blockstudio": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "npm run build && vitest run --project e2e",
    "test:watch": "vitest --project unit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "execa": "^9.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^13.0.0",
    "ink": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.0.0",
    "zod": "^3.0.0"
  }
}
