{
	"$schema": "https://blockstudio.dev/schema/block",
	"name": "bsui/time-picker",
	"title": "Time Picker",
	"category": "design",
	"icon": "clock",
	"blockstudio": {
		"interactivity": {
			"enqueue": true
		},
		"attributes": [
			{
				"id": "name",
				"type": "text",
				"label": "Name"
			},
			{
				"id": "defaultValue",
				"type": "text",
				"label": "Default Value (HH:MM)"
			},
			{
				"id": "step",
				"type": "number",
				"label": "Minute step",
				"default": 1
			},
			{
				"id": "disabled",
				"type": "toggle",
				"label": "Disabled",
				"default": false
			},
			{
				"id": "nameAlt",
				"type": "text",
				"label": "Form Name (alt)"
			},
			{
				"id": "onChange",
				"type": "text",
				"hidden": true
			},
			{
				"id": "value",
				"type": "text"
			}
		]
	}
}
