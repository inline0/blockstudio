{
	"$schema": "https://blockstudio.dev/schema/block",
	"name": "bsui/radio",
	"title": "Radio",
	"category": "design",
	"icon": "marker",
	"parent": ["bsui/radio-group"],
	"usesContext": ["bsui/radio-group"],
	"blockstudio": {
		"attributes": [
			{
				"id": "value",
				"type": "text",
				"label": "Value"
			},
			{
				"id": "label",
				"type": "richtext"
			},
			{
				"id": "disabled",
				"type": "toggle",
				"label": "Disabled",
				"default": false
			},
			{
				"id": "bindText",
				"type": "text",
				"label": "Bind Text Directive",
				"hidden": true
			}
		]
	}
}
