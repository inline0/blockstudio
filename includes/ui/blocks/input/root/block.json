{
	"$schema": "https://blockstudio.dev/schema/block",
	"name": "bsui/input",
	"title": "Input",
	"category": "design",
	"icon": "edit",
	"usesContext": ["bsui/form"],
	"blockstudio": {
		"attributes": [
			{
				"id": "type",
				"type": "select",
				"label": "Type",
				"options": [
					{
						"label": "Text",
						"value": "text"
					},
					{
						"label": "Email",
						"value": "email"
					},
					{
						"label": "Password",
						"value": "password"
					},
					{
						"label": "URL",
						"value": "url"
					},
					{
						"label": "Tel",
						"value": "tel"
					},
					{
						"label": "Search",
						"value": "search"
					}
				],
				"default": "text"
			},
			{
				"id": "name",
				"type": "text",
				"label": "Name"
			},
			{
				"id": "placeholder",
				"type": "text",
				"label": "Placeholder"
			},
			{
				"id": "disabled",
				"type": "toggle",
				"label": "Disabled",
				"default": false
			},
			{
				"id": "required",
				"type": "toggle",
				"label": "Required",
				"default": false
			},
			{
				"id": "defaultValue",
				"type": "text",
				"label": "Default Value"
			},
			{
				"id": "nameAlt",
				"type": "text",
				"label": "Form Name (alt)"
			},
			{
				"id": "onChange",
				"type": "text"
			},
			{
				"id": "value",
				"type": "text"
			}
		]
	}
}
