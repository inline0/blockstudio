{
	"$schema": "https://blockstudio.dev/schema/block",
	"name": "bsui/meter",
	"title": "Meter",
	"category": "design",
	"icon": "minus",
	"blockstudio": {
		"attributes": [
			{
				"id": "value",
				"type": "number",
				"label": "Value",
				"default": 0
			},
			{
				"id": "min",
				"type": "number",
				"label": "Min",
				"default": 0
			},
			{
				"id": "max",
