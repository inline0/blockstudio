{
	"$schema": "https://blockstudio.dev/schema/block",
	"name": "bsui/otp-input",
	"title": "OTP Input",
	"category": "design",
	"icon": "lock",
	"blockstudio": {
		"interactivity": {
			"enqueue": true
		},
		"attributes": [
			{
				"id": "name",
				"type": "text",
				"label": "Name"
			},
			{
				"id": "length",
				"type": "number",
				"label": "Code Length",
				"default": 6
			},
			{
				"id": "disabled",
				"type": "toggle",
				"label": "Disabled",
				"default": false
			},
			{
				"id": "nameAlt",
				"type": "text",
				"label": "Form Name (alt)"
			},
			{
				"id": "onChange",
				"type": "text",
				"hidden": true
			}
		]
	}
}
