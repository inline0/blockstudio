{
  "$schema": "https://blockstudio.dev/schema/block",
  "name": "blockstudio/type-populate-dynamic",
  "title": "Dynamic Populate Test",
  "category": "blockstudio-test-native",
  "icon": "star-filled",
  "blockstudio": {
    "attributes": [
      {
        "id": "post_type",
        "type": "select",
        "label": "Post Type",
        "default": "page",
        "options": [
          { "label": "Pages", "value": "page" },
          { "label": "Posts", "value": "post" }
        ]
      },
      {
        "id": "selected_post",
        "type": "select",
        "label": "Select Post",
        "populate": {
          "type": "query",
          "query": "posts",
          "arguments": {
            "post_type": "{attributes.post_type}",
            "numberposts": 5
          }
        }
      }
    ]
  }
}
